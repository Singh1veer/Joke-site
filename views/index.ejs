<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jokes of the Day</title>
  <link rel="stylesheet" href="/style.css">
 <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <header class="stage">
    <span class="mic-icon">🎤</span>
    <h1>Joke of the <span>Day</span></h1>
    <p class="subtitle">Fresh laughs, daily delivery</p>
  </header>

  <div class="divider"></div>

  <div class="controls">
    <div class="btn-group" id="one">
      <button type="button" class="btn btn-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
        Type of Joke <%= type %>
      </button>
      <ul class="dropdown-menu">
        <li><a class="dropdown-item" href="/?category=<%=category %>&type=single">Single</a></li>
        <li><a class="dropdown-item" href="/?category=<%=category %>&type=twopart">Two-Part</a></li>
      </ul>
    </div>

    <div class="btn-group" id="two">
      <button type="button" class="btn btn-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
        Category <%= category %>
      </button>
         <ul class="dropdown-menu">
      <li><a class="dropdown-item" href="/?category=Any&type=<%= type %>">Any</a></li>
      <li><a class="dropdown-item" href="/?category=Programming&type=<%= type %>">Programming</a></li>
      <li><a class="dropdown-item" href="/?category=Misc&type=<%= type %>">Misc</a></li>
      <li><a class="dropdown-item" href="/?category=Dark&type=<%= type %>">Dark</a></li>
      <li><a class="dropdown-item" href="/?category=Pun&type=<%= type %>">Pun</a></li>
      <li><a class="dropdown-item" href="/?category=Spooky&type=<%= type %>">Spooky</a></li>
      <li><a class="dropdown-item" href="/?category=Christmas&type=<%= type %>">Christmas</a></li>
    </ul>
    </div>
  </div>
<div class="joke-card">
     <span class="quote-mark">"</span>

    <% if (locals.joke) { %>
      <span class="tag"><%= joke.category %></span>
      <% if (joke.type === "single") { %>
        <p class="card-text"><%= joke.joke %></p>
      <% } else { %>
        <h5 class="card-title"><%= joke.setup %></h5>
        <p class="card-text"><%= joke.delivery %></p>
      <% } %>
    <% } %>

    <a href="/?category=<%= category %>&type=<%= type %>" class="reveal-btn">
      😂 Next Joke
    </a>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
